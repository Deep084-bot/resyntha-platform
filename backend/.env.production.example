# =============================================================================
# Resyntha — Production Environment Template
# =============================================================================
# Copy to .env and fill in all values.  Never commit secrets.
#
# Required for production:
#   - SECRET_KEY (min 32 chars)
#   - DATABASE_URL
#   - REDIS_URL
#   - GROQ_API_KEY or OPENAI_API_KEY
#   - TRUSTED_HOSTS (do NOT use "*")
# =============================================================================

APP_NAME=resyntha
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false

# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_HEX_CHAR_STRING

DATABASE_URL=postgresql+psycopg://user:password@host:5432/resyntha?sslmode=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30.0
DB_POOL_RECYCLE=1800
REDIS_URL=rediss://default:password@host:6379

API_V1_PREFIX=/api/v1
# Your production domain(s)
TRUSTED_HOSTS=api.resyntha.app,resyntha.app

CORS_ORIGINS=https://app.resyntha.app
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS,HEAD
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,Accept,Origin,User-Agent,DNT,Cache-Control,X-Mx-ReqToken,Keep-Alive,X-Frame-Options,X-Content-Type-Options
CORS_ALLOW_CREDENTIALS=true

# Disable docs in production unless needed
OPENAPI_ENABLED=false
DOCS_ENABLED=false
REDOC_ENABLED=false

LOG_FORMAT=json
LOG_LEVEL=INFO

LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
OPENAI_API_KEY=

RETRIEVAL_PROVIDERS=semantic_scholar,arxiv,openalex

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Caching ------------------------------------------------------------------
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
CACHE_GRAPH_TTL=1800
CACHE_LANDSCAPE_TTL=1800
CACHE_GAP_REPORT_TTL=1800
CACHE_KNOWLEDGE_PACKAGE_TTL=1800
CACHE_RETRIEVAL_TTL=600
CACHE_INVESTIGATION_TTL=300

# --- Rate Limiting ------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=redis
DEFAULT_RATE_LIMIT=120
COPILOT_RATE_LIMIT=20
INVESTIGATION_RATE_LIMIT=10
RUN_RATE_LIMIT=5
RATE_LIMIT_WINDOW=60

# --- Metrics ------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PATH=/api/v1/metrics
METRICS_NAMESPACE=resyntha
METRICS_SUBSYSTEM=backend

# --- Security -----------------------------------------------------------------
SECURITY_HEADERS_ENABLED=true
REQUEST_TIMEOUT_SECONDS=30.0
MAX_REQUEST_SIZE=1048576
MAX_JSON_SIZE=1048576
MAX_UPLOAD_SIZE=10485760
CSP_ENABLED=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
