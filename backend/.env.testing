# =============================================================================
# Resyntha — Testing Environment
# =============================================================================
# Used by pytest.  Uses SQLite to avoid external database dependencies.
# Redis and LLM providers are optional for unit tests.
# =============================================================================

APP_NAME=resyntha
APP_VERSION=0.1.0
ENVIRONMENT=testing
DEBUG=false

SECRET_KEY=test-secret-key-for-testing-only-1234567890

# SQLite is fast and requires no external service — ideal for CI/test
DATABASE_URL=sqlite:///./test.db

# Redis not required for unit tests; set to empty to disable
REDIS_URL=

API_V1_PREFIX=/api/v1
TRUSTED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

OPENAPI_ENABLED=false
DOCS_ENABLED=false
REDOC_ENABLED=false

LOG_FORMAT=json
LOG_LEVEL=WARNING

LLM_PROVIDER=groq
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
OPENAI_API_KEY=

RETRIEVAL_PROVIDERS=semantic_scholar,arxiv,openalex

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
