# =============================================================================
# Resyntha — Development Environment
# =============================================================================
# Source this file with: export $(grep -v '^#' .env.development | xargs)
# Or use pydantic-settings (it auto-discovers .env by default).
# =============================================================================

APP_NAME=resyntha
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Dev-only secret key (32 chars, never use in production)
SECRET_KEY=dev-insecure-7f3a9c2b1e8d4a5f6c7b8a9d0e1f2a3b

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/resyntha
REDIS_URL=redis://localhost:6379/0

API_V1_PREFIX=/api/v1
TRUSTED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

OPENAPI_ENABLED=true
DOCS_ENABLED=true
REDOC_ENABLED=true

LOG_FORMAT=console
LOG_LEVEL=DEBUG

LLM_PROVIDER=groq
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
OPENAI_API_KEY=

RETRIEVAL_PROVIDERS=semantic_scholar,arxiv,openalex

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
