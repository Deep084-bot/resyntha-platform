# =============================================================================
# Resyntha — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in real values for your target environment.
# Never commit .env to version control.
# =============================================================================
#
# Application
# ---------------------------------------------------------------------------
# APP_NAME       — Human-readable application name (used in logging, OpenAPI).
# APP_VERSION    — SemVer string that matches the pyproject.toml version.
# ENVIRONMENT    — Deployment context: development | testing | production.
# DEBUG          — Enable debug-level logging and verbose error responses.
APP_NAME=resyntha
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# Security
# ---------------------------------------------------------------------------
# SECRET_KEY     — HMAC signing key for JWT tokens, session cookies, etc.
#                  Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Database
# ---------------------------------------------------------------------------
# DATABASE_URL   — Full PostgreSQL connection string (scheme+driver, user,
#                  password, host, port, database).
#                  Format: postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/resyntha

# Redis
# ---------------------------------------------------------------------------
# REDIS_URL      — Connection string for Redis (used by ARQ workers and
#                  caching layers).
REDIS_URL=redis://localhost:6379/0

# AI / External Services (future sprints)
# ---------------------------------------------------------------------------
# GROQ_API_KEY   — API key for Groq LLM inference endpoints.
GROQ_API_KEY=
