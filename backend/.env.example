# =============================================================================
# Resyntha — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.  Never commit .env to
# version control.
#
# Supported environments via ENVIRONMENT: development | testing | production
# =============================================================================

# --- Application --------------------------------------------------------------
APP_NAME=resyntha
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

# --- Security -----------------------------------------------------------------
# Minimum 32 characters in production.  Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key

# --- Security -----------------------------------------------------------------
# SECURITY_HEADERS_ENABLED=true
# REQUEST_TIMEOUT_SECONDS=30.0
# MAX_REQUEST_SIZE=1048576      # 1 MB – general request body
# MAX_JSON_SIZE=1048576         # 1 MB – JSON bodies
# MAX_UPLOAD_SIZE=10485760      # 10 MB – file uploads
# CSP_ENABLED=true
# CSP_DIRECTIVES=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# --- Database -----------------------------------------------------------------
# PostgreSQL (production/development):
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/resyntha
# SQLite (testing only):
# DATABASE_URL=sqlite:///./test.db
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30.0
# DB_POOL_RECYCLE=1800

# --- Redis --------------------------------------------------------------------
# Redis with TLS (production, e.g. Upstash):
# REDIS_URL=rediss://default:password@host:6379
# Redis local (development):
REDIS_URL=redis://localhost:6379/0

# --- API ----------------------------------------------------------------------
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed Host headers
TRUSTED_HOSTS=localhost,127.0.0.1

# --- CORS ---------------------------------------------------------------------
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
# CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS,HEAD
# CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,Accept,Origin,User-Agent,DNT,Cache-Control,X-Mx-ReqToken,Keep-Alive,X-Frame-Options,X-Content-Type-Options
# CORS_ALLOW_CREDENTIALS=true

# --- OpenAPI / Docs -----------------------------------------------------------
OPENAPI_ENABLED=true
DOCS_ENABLED=true
REDOC_ENABLED=true

# --- Logging ------------------------------------------------------------------
LOG_FORMAT=console      # console | json
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL

# --- LLM Provider -------------------------------------------------------------
LLM_PROVIDER=groq        # groq | openai
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
OPENAI_API_KEY=

# --- Retrieval ----------------------------------------------------------------
# Comma-separated: semantic_scholar, arxiv, openalex
RETRIEVAL_PROVIDERS=semantic_scholar,arxiv,openalex

# --- Embeddings ---------------------------------------------------------------
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Caching ------------------------------------------------------------------
# CACHE_ENABLED=true
# CACHE_DEFAULT_TTL=300
# CACHE_GRAPH_TTL=1800
# CACHE_LANDSCAPE_TTL=1800
# CACHE_GAP_REPORT_TTL=1800
# CACHE_KNOWLEDGE_PACKAGE_TTL=1800
# CACHE_RETRIEVAL_TTL=600
# CACHE_INVESTIGATION_TTL=300

# --- Rate Limiting ------------------------------------------------------------
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_BACKEND=redis     # redis | memory
# DEFAULT_RATE_LIMIT=120
# COPILOT_RATE_LIMIT=20
# INVESTIGATION_RATE_LIMIT=10
# RUN_RATE_LIMIT=5
# RATE_LIMIT_WINDOW=60

# --- Metrics ------------------------------------------------------------------
# METRICS_ENABLED=true
# METRICS_PATH=/api/v1/metrics
# METRICS_NAMESPACE=resyntha
# METRICS_SUBSYSTEM=backend
