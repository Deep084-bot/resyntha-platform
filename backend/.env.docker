# Docker Compose environment
# These are safe defaults for local Docker development.
# Override via docker-compose.override.yml or shell environment.

APP_NAME=resyntha
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

SECRET_KEY=dev-insecure-docker-7f3a9c2b1e8d4a5f6c7b8a9d0e1f2a3b

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/resyntha
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30.0
DB_POOL_RECYCLE=1800

REDIS_URL=redis://redis:6379/0

API_V1_PREFIX=/api/v1
TRUSTED_HOSTS=localhost,127.0.0.1,backend,frontend

CORS_ORIGINS=http://localhost:80,http://localhost,http://localhost:5173,http://localhost:3000

OPENAPI_ENABLED=true
DOCS_ENABLED=true
REDOC_ENABLED=true

LOG_FORMAT=console
LOG_LEVEL=DEBUG

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

RETRIEVAL_PROVIDERS=semantic_scholar,arxiv,openalex

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300

RATE_LIMIT_ENABLED=true
RATE_LIMIT_BACKEND=redis
DEFAULT_RATE_LIMIT=120

METRICS_ENABLED=true
METRICS_PATH=/api/v1/metrics
METRICS_NAMESPACE=resyntha
METRICS_SUBSYSTEM=backend

SECURITY_HEADERS_ENABLED=true
REQUEST_TIMEOUT_SECONDS=30.0
MAX_REQUEST_SIZE=1048576
